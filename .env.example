# Database
DATABASE_URL="postgresql://user:password@localhost:5432/grocery?schema=public"

# Auth (NextAuth / Auth.js)
# Required: secret for signing session cookies (e.g. openssl rand -base64 32)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Base URL of the app (use https in production)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — required for "Continue with Google"
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: https://your-domain.com/api/auth/callback/google (and http://localhost:3000/api/auth/callback/google for dev)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Legacy names (still supported)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# OpenAI (for ingredient extraction)
OPENAI_API_KEY="sk-..."

# Encrypt store session cookies (32+ chars)
ENCRYPTION_KEY="your-32-char-secret-key-here!!"

# Agent: set to "false" to see browser during shopping
# AGENT_HEADLESS=true
